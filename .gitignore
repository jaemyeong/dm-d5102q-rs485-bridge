*.spiffs.bin
*.img

# Local firmware secrets and generated board files
secrets.h
firmware/*/secrets.h
firmware/*/data/*.bin
firmware/*/build/

# Python caches and virtual environments
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.venv/
venv/

# Capture binaries and raw protocol logs
captures/*
!captures/.gitkeep
!captures/README.md
!captures/README.en.md
*.pcap
*.pcapng
*.logicdata
*.sal

# IDE and editor metadata
.idea/
.vscode/
*.swp
*.swo
*.swn
