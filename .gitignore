# Arduino / ESP32 build outputs
build/
*.elf
*.map
*.bin
*.hex
*.uf2
*.o
*.a
*.d
*.lst
*.su
*.stackdump

# LittleFS / filesystem images
*.littlefs.bin
littlefs.bin
